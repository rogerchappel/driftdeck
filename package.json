{
  "name": "driftdeck",
  "version": "0.1.0",
  "description": "Local-first dependency and runtime drift snapshots for multi-repo workspaces.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "driftdeck": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test dist/tests/**/*.test.js",
    "smoke": "npm run build && bash scripts/smoke-test.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "cli",
    "dependencies",
    "drift",
    "git",
    "workspace"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.15.24",
    "typescript": "^5.8.3"
  }
}
